{
    "version": 2,
    "builds": [
        { "src": "api/index.php", "use": "vercel-php@0.9.0" },
        { "src": "/public/**", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/build/(.*)", "dest": "/public/build/$1" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }
            ]
        }
    ]
}